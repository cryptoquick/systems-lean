#!/usr/bin/env bash
# SPDX-License-Identifier: Unlicense
# Repo pre-commit (after global GPG guard). Same gates as `just pre-commit`.
set -euo pipefail
root=$(git rev-parse --show-toplevel)
cd "$root"
if command -v just >/dev/null 2>&1; then
  exec just pre-commit
fi
exec ./script/check-all.sh --staged
